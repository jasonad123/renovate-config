{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests",
  ],
    "labels": ["dependencies", "renovate"],
  // The dependency dashboard is an issue created in the repo that tracks the
  // dependencies that Renovate will work againse
  "dependencyDashboard": true,
  "prHourlyLimit": 4,
  "minimumReleaseAge" : "7 days",
  "packageRules": [
    {
      "description": "Group all non-major dependencies together",
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch",
      "automerge": false
    },

    {
      "description": "Group Tailwind ecosystem updates",
      "matchPackageNames": ["^@tailwindcss/", "tailwindcss"],
      "groupName": "Tailwind packages",
      "schedule": ["* 0-3 * * 1"]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "schedule": ["* 0-3 * * 1"],
      "pinDigests": true
    },
    {
      "description": "Separate major updates",
      "matchUpdateTypes": ["major"],
      "labels": ["breaking-change"]
    }
  ]
}