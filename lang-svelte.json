{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "group:vite"
  ],
  "ignorePaths": [
    "Dockerfile.dhi"
  ],
  "packageRules": [
    {
      "description": "Group Svelte ecosystem updates",
      "matchPackageNames": ["@sveltejs/**", "svelte", "svelte-*"],
      "groupName": "Svelte packages",
      "schedule": ["* 0-3 * * 1"]
    }
  ],
  "postUpdateOptions": [
    "pnpmDedupe",
    "npmDedupe"
  ]
}
